    "scripts": {
        "build:gomoku": "webpack --config ./bundler/webpack.gomoku.js",
        "build:satellite": "webpack --config ./bundler/webpack.satellite.js",
        "build": "npm run build:gomoku && npm run build:satellite && webpack --config ./bundler/webpack.prod.js",
        "dev": "npm run build:gomoku && npm run build:satellite && webpack serve --config ./bundler/webpack.dev.js",
        "preview": "python3 -m http.server 3090 --directory docs",
        "test:smoke": "playwright test",
        "verify:docs": "node scripts/verify-docs.cjs"
    },
