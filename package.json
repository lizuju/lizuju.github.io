        "babel-loader": "^8.2.3",
        "bezier-easing": "^2.1.0",
        "camera-controls": "^1.34.2",
        "clean-webpack-plugin": "^4.0.0",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "^6.5.1",
        "file-loader": "^6.2.0",
